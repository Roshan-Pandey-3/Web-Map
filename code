            { name: "Gorkha Memorial Museum", type: "Recreational area", lat: 28.2459957, lng: 83.9886569, distance: 900, area: "Deep", subCat: "Hangout Spot" },
            { name: "Seti River Near Deep", type: "Recreational area", lat: 28.2514543, lng: 83.9781417, distance: 800, area: "Deep", subCat: "Riverside area" },
            { name: "Bhalam Suspension Bridge", type: "Recreational area", lat: 28.2556293, lng: 83.9851576, distance: 1200, area: "Bhalam", subCat: "Suspension Bridge" }
        ];

        // WRC center coordinates (approx based on campus gate)
        const WRC_CENTER = [28.2565, 83.9777];

        // Initialize map
        const map = L.map('map').setView(WRC_CENTER, 15.5);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> & CartoDB',
            subdomains: 'abcd',
            maxZoom: 19
        }).addTo(map);

        // Color mapping
        const colors = {
            "Grocery": "#4CAF50", "Restaurant and cafe": "#FF5722", "Recreational area": "#2196F3",
            "Health facility": "#E91E63", "Bank": "#9C27B0", "ATM": "#FF9800", "Stationery": "#00BCD4",
            "Barber Shop": "#795548", "Tailor": "#607D8B", "GYM": "#3F51B5", "Driving School": "#FFEB3B",
            "Hostel": "#8BC34A", "Hostels": "#8BC34A"
        };

        function getMarkerIcon(color) {
            return L.divIcon({
                html: `<div style="background-color:${color}; width:16px; height:16px; border-radius:50%; border:2px solid white; box-shadow:0 1px 4px rgba(0,0,0,0.4); transition: transform 0.1s;"></div>`,
                iconSize: [20, 20],
                iconAnchor: [10, 10],
                popupAnchor: [0, -8]
            });
        }

        let allMarkers = [];
        let currentBufferCircle = null;
        let currentBufferRadius = null;

        // function to add markers with hover tooltip & popup details
        function addMarkers(filterType = "all") {
            allMarkers.forEach(m => map.removeLayer(m));
            allMarkers = [];

            amenitiesData.forEach(item => {
                if (filterType !== "all" && item.type !== filterType) return;
                if (!item.lat || !item.lng) return;
                const color = colors[item.type] || "#AAAAAA";
                const marker = L.marker([item.lat, item.lng], { icon: getMarkerIcon(color) });
                
                // Hover tooltip (brief)
                marker.bindTooltip(`<b>${item.name}</b><br>${item.type} | ${item.distance}m from WRC`, {
                    sticky: true,
                    className: "hover-tooltip-custom",
                    offset: [10, -10]
                });
                
                // Popup on click with more details
                let popupHtml = `<div style="font-size:13px; min-width:170px;"><b>🏪 ${item.name}</b><br>
                                📌 Type: ${item.type}<br>📍 Area: ${item.area || 'N/A'}<br>
                                📏 Distance from WRC: ${item.distance} meters`;
                if (item.subCat) popupHtml += `<br>🔖 Sub-category: ${item.subCat}`;
                popupHtml += `</div>`;
                marker.bindPopup(popupHtml);
                
                marker.on('mouseover', () => {
                    document.getElementById('hoverDetails').innerHTML = `<span style="color:#FFB347;">✨ ${item.name}</span> (${item.type}) — ${item.distance}m from WRC<br><span style="font-size:11px;">📌 ${item.area || 'Unknown area'}</span>`;
                });
                marker.on('mouseout', () => {
                    document.getElementById('hoverDetails').innerHTML = `Name, type & distance will appear here`;
                });
                
                marker.addTo(map);
                allMarkers.push(marker);
            });
        }

        // draw buffer circle with given radius (meters)
        function drawBuffer(radiusMeters) {
            if (currentBufferCircle) {
                map.removeLayer(currentBufferCircle);
                currentBufferCircle = null;
            }
            if (radiusMeters && radiusMeters > 0) {
                currentBufferCircle = L.circle(WRC_CENTER, {
                    radius: radiusMeters,
                    color: '#e34234',
                    weight: 2.5,
                    fillColor: '#ff6347',
                    fillOpacity: 0.1,
                    dashArray: '6, 8'
                }).addTo(map).bindTooltip(`📐 ${radiusMeters}m service radius from WRC`, { sticky: true, direction: 'top' });
                currentBufferRadius = radiusMeters;
            } else {
                currentBufferRadius = null;
            }
        }

        // handle buffer button clicks
        const bufferBtns = document.querySelectorAll('.buffer-btn');
        bufferBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const radius = parseInt(btn.getAttribute('data-radius'), 10);
                drawBuffer(radius);
                // update active style
                bufferBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Show amenities within currently selected buffer
        document.getElementById('showNearbyBtn').addEventListener('click', () => {
            if (!currentBufferRadius) {
                alert("⚠️ Please select a buffer radius first (200m, 500m, 1km, or 2km).");
                return;
            }
            let nearbyList = [];
            amenitiesData.forEach(item => {
                if (!item.lat || !item.lng) return;
                const distanceMeters = map.distance(WRC_CENTER, [item.lat, item.lng]);
                if (distanceMeters <= currentBufferRadius) {
                    nearbyList.push(`✓ ${item.name} (${item.type}) - ${Math.round(distanceMeters)}m`);
                }
            });
            if (nearbyList.length === 0) {
                alert(`ℹ️ No amenities found within ${currentBufferRadius}m of WRC.`);
            } else {
                alert(`🏆 ${nearbyList.length} amenities within ${currentBufferRadius}m:\n\n${nearbyList.join('\n')}`);
            }
        });

        // populate filter dropdown with unique types
        const typeSet = new Set(amenitiesData.map(d => d.type));
        const filterSelect = document.getElementById('filterTypeSelect');
        typeSet.forEach(t => {
            const option = document.createElement('option');
            option.value = t;
            option.textContent = t;
            filterSelect.appendChild(option);
        });
        
        filterSelect.addEventListener('change', (e) => {
            addMarkers(e.target.value);
        });

        // reset view: clear buffer, reset filter, zoom to WRC
        document.getElementById('resetViewBtn').addEventListener('click', () => {
            map.setView(WRC_CENTER, 15.5);
            filterSelect.value = "all";
            addMarkers("all");
            if (currentBufferCircle) {
                map.removeLayer(currentBufferCircle);
                currentBufferCircle = null;
                currentBufferRadius = null;
            }
            bufferBtns.forEach(b => b.classList.remove('active'));
        });

        // Add scale and custom legend
        L.control.scale({ metric: true, imperial: false }).addTo(map);
        
        const legendControl = L.control({ position: 'bottomright' });
        legendControl.onAdd = function () {
            const div = L.DomUtil.create('div', 'legend');
            div.innerHTML = '<strong>🏷️ Amenity Types</strong><br>';
            for (let [type, col] of Object.entries(colors)) {
                div.innerHTML += `<i style="background:${col};"></i> ${type}<br>`;
            }
            div.innerHTML += `<hr><span style="font-size:10px;">🖱️ Hover on markers<br>🔍 Click popup for full info</span>`;
            return div;
        };
        legendControl.addTo(map);
        
        // WRC marker (campus reference)
        L.marker(WRC_CENTER, {
            icon: L.divIcon({ html: '🏫', iconSize: [24, 24], className: 'wrc-marker' }),
            zIndexOffset: 1000
        }).addTo(map).bindTooltip('🎓 WRC Campus (Western Regional College)', { permanent: false }).openTooltip();
        
        // initial load all markers
        addMarkers("all");
        // optional: set default active buffer to 200m to match original experience
        setTimeout(() => {
            drawBuffer(200);
            document.querySelector('.buffer-btn[data-radius="200"]').classList.add('active');
        }, 500);
    </script>
</body>
</html>
